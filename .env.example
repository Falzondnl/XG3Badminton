# XG3 Badminton Platform — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# ── Service ──────────────────────────────────────────────────────────────────
XG3_ENV=production               # production | staging | development
XG3_PORT=8009
XG3_LOG_LEVEL=info               # debug | info | warning | error

# ── Data Feeds ───────────────────────────────────────────────────────────────
OPTIC_ODDS_API_KEY=your_optic_odds_key_here
FLASHSCORE_API_KEY=your_flashscore_key_here
BWF_RANKINGS_API_KEY=your_bwf_key_here

# ── Pinnacle / Exchange Feeds (for calibration) ───────────────────────────────
PINNACLE_API_KEY=your_pinnacle_key_here
BETFAIR_APP_KEY=your_betfair_app_key_here
BETFAIR_SESSION_TOKEN=your_betfair_session_token_here

# ── Redis (live state, caching) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Database (historical match data) ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://xg3:password@localhost:5432/xg3_badminton

# ── ML Model Storage ─────────────────────────────────────────────────────────
MODEL_DIR=/app/models            # path to trained .pkl files
MODEL_VERSION=latest

# ── Trading Controls ─────────────────────────────────────────────────────────
MAX_STAKE_GBP=5000
MATCH_MAX_LOSS_CAP_GBP=50000
DAILY_MAX_LOSS_GBP=200000

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
SENTRY_DSN=                      # leave blank to disable Sentry

# ── Security ─────────────────────────────────────────────────────────────────
API_SECRET_KEY=change_me_to_a_random_256bit_secret
ALLOWED_HOSTS=localhost,127.0.0.1
